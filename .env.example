APP_NAME="LVTN Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL frontend React (Vercel) - dùng cho CORS
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

# -----------------------------------------------
# DATABASE - Aiven MySQL
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=your-service.aivencloud.com
DB_PORT=3306
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=

# Aiven yêu cầu SSL - bắt buộc
DB_SSL_MODE=REQUIRED
MYSQL_ATTR_SSL_CA=/path/to/ca.pem

# -----------------------------------------------
# SESSION / CACHE
# -----------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

# -----------------------------------------------
# SANCTUM - Auth token cho React SPA
# -----------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:5173,your-app.vercel.app

# -----------------------------------------------
# QUEUE / FILESYSTEM
# -----------------------------------------------
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

# -----------------------------------------------
# MAIL (chưa dùng ở v1, để đây cho sau)
# -----------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@lvtn.local"
MAIL_FROM_NAME="${APP_NAME}"
