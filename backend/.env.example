APP_NAME="QuanLyLVTN_STU"
APP_ENV=local
APP_KEY=base64:xUORVAJLIcoFvJKxYobRt5iGHfeyuZebaiDASystJ8c=
APP_DEBUG=true

# --- 1. CHỌN LINK CHẠY WEB (APP_URL) ---
# Dùng cho Mac (MAMP) -
APP_URL=http://localhost:8888/QuanLy_LuanVan_TN-main/backend/public
# Dùng cho Windows/Serve (Tạm khóa) -
# APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- 2. CẤU HÌNH DATABASE ĐA NỀN TẢNG ---
# ============================================================

# --- CẤU HÌNH CHO MAC (MAMP) - ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=root

# --- CẤU HÌNH CHO WINDOWS (XAMPP/SERVE) - ---
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=quanly_lvtn
# DB_USERNAME=root
# DB_PASSWORD=
# ============================================================

SESSION_DRIVER=file
SESSION_LIFETIME=120
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MAIL_MAILER=log
